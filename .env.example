# Azure AD (App Registration with Dataverse permission)
AZURE_TENANT_ID=YOUR_AZURE_TENANT_ID
AZURE_CLIENT_ID=YOUR_AZURE_CLIENT_ID
AZURE_CLIENT_SECRET=YOUR_AZURE_CLIENT_SECRET

# Dataverse
DATAVERSE_URL=https://your-org.crm2.dynamics.com

# Table logical names (plural, lowercase - check in maker.powerapps.com)
DV_HISTORY_TABLE=cr1a0_bank_statements_2
DV_COA_TABLE=cr1a0_dplanodecontas_nvel2
DV_OUTPUT_TABLE=cr1a0_bank_statements_2

# Column logical names in the historical table
DATE_COL=cr1a0_date
DESC_COL=cr1a0_description
AMOUNT_COL=cr1a0_amount
INOUT_COL=cr1a0_inout
COMPANY_COL=cr1a0_companyname
CLASS_COL=cr1a0_classification
DESC2_COL=cr1a0_description2
COA_ID_COL=cr1a0_idplanodeconta


# Column logical names in the CoA table
COA_ID3_COL=cr1a0_id_3
COA_NAME3_COL=cr1a0_conta
COA_ID2_COL=cr1a0_id_2
COA_NAME2_COL=cr1a0_contanivel2
COA_ID1_COL=cr1a0_id_1
COA_NAME1_COL=cr1a0_id_1_conta

# Metadata columns written by the classifier (create these in Dataverse)
CLASSIFIED_BY_COL=cr1a0_classifiedby
SOURCE_FILE_COL=cr1a0_sourcefile
CLASSIFIED_AT_COL=cr1a0_classifiedat
CONFIDENCE_SCORE_COL=cr1a0_confidencescore

# Classification confidence threshold (rows below this get classified_by = "Needs Review")
CONFIDENCE_THRESHOLD=0.8

# How many months old an AI-classified row must be before it's used for training
AI_TRAINING_LAG_MONTHS=2
